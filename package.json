{
  "name": "live-studio-experience-assistant",
  "version": "0.1.0",
  "description": "MVP GUI for AI-assisted TikTok LIVE Studio product experience testing.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.bytedance.live-studio-experience-assistant.mvp",
    "productName": "LIVE Studio experience assistant",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "roles/**/*",
      "schemas/**/*",
      "tools/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "requireAdministrator"
    }
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "playwright-core": "^1.60.0"
  }
}
